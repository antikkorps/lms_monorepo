# =============================================================================
# LMS Platform - Production Environment Variables
# =============================================================================
# Copy to .env.production and fill in secrets before deploying

# -----------------------------------------------------------------------------
# Database - PostgreSQL (Docker internal network)
# -----------------------------------------------------------------------------
POSTGRES_USER=lms
POSTGRES_PASSWORD=          # Generate: openssl rand -base64 32
POSTGRES_DB=lms
DATABASE_URL=postgres://lms:YOUR_PASSWORD_HERE@postgres:5432/lms

# -----------------------------------------------------------------------------
# Cache - Redis (Docker internal network)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
API_PORT=3000

# JWT Secret — Generate: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS Origins (production domains)
CORS_ORIGINS=https://iqon-ia.com,https://app.iqon-ia.com

# Rate Limiting
RATE_LIMIT_B2C_WINDOW_MS=60000
RATE_LIMIT_B2C_MAX=100
RATE_LIMIT_B2B_WINDOW_MS=60000
RATE_LIMIT_B2B_MAX=500
RATE_LIMIT_B2B_PREMIUM_WINDOW_MS=60000
RATE_LIMIT_B2B_PREMIUM_MAX=1000
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10

# -----------------------------------------------------------------------------
# Frontend Configuration (build-time)
# -----------------------------------------------------------------------------
VITE_API_URL=https://api.iqon-ia.com
VITE_LANDING_URL=https://iqon-ia.com
VITE_STRIPE_PUBLISHABLE_KEY=    # pk_live_...

# -----------------------------------------------------------------------------
# Stripe (Payment)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=              # sk_live_...
STRIPE_WEBHOOK_SECRET=          # whsec_...
STRIPE_PUBLISHABLE_KEY=         # pk_live_...

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=mailjet
EMAIL_FROM=noreply@iqon-ia.com
EMAIL_FROM_NAME=IQON-IA
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_CONTACT_LIST_ID=

# -----------------------------------------------------------------------------
# SSO (OAuth2)
# -----------------------------------------------------------------------------
SSO_CALLBACK_URL=https://api.iqon-ia.com/api/v1/auth/sso/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# -----------------------------------------------------------------------------
# Cloudflare (R2 Storage + Stream)
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lms-assets
R2_PUBLIC_URL=https://assets.iqon-ia.com

# -----------------------------------------------------------------------------
# Backup (pg_dump → R2 via rclone)
# -----------------------------------------------------------------------------
# R2 credentials are reused from Storage section above
# BACKUP_RETENTION_DAYS=30      # Optional, default 30

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Admin Setup (initial super admin, run once)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@iqon-ia.com
ADMIN_PASSWORD=                 # Min 12 chars
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=IQON
